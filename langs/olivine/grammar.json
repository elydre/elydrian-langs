{
    "name": "olivine",
    "patterns": [
        {
            "name": "keyword.control.olivine",
            "match": "^\\s*(?i)\\b(END|IF|ELSE|FOR|WHILE|ELIF|FUNC|RETURN|BREAK|CONTINUE)\\b"
        },
        {
            "name": "string.quoted.multi.olivine",
            "begin": "'''",
            "end": "'''"
        },
        {
            "name": "string.quoted.single.olivine",
            "begin": "'",
            "end": "'|$",
            "patterns": [
                {
                    "name": "constant.character.escape.olivine",
                    "match": "\\\\."
                },
                {
                    "include": "#variable"
                },
                {
                    "include": "#subFunction"
                }
            ]
        },
        {
            "name": "constant.numeric",
            "patterns": [
                {
                    "name": "constant.numeric.integer.olivine",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        {
            "name": "comment.line.double-slash.olivine",
            "begin": "//",
            "end": "$"
        },
        {
            "include": "#variable"
        },
        {
            "include": "#subFunction"
        },
        {
            "name": "entity.name.function.olivine",
            "match": "^\\s*[A-Za-z0-9_]*"
        }
    ],
    "repository": {
        "variable": {
            "name": "variable.other.olivine",
            "match": "!+[a-zA-Z0-9_#]+"
        },
        "subFunction": {
            "name": "meta.command-substitution.olivine",
            "begin": "!\\(",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.section.embedded.begin.olivine"
                }
            },
            "end": "\\)",
            "endCaptures": {
                "0": {
                    "name": "punctuation.section.embedded.end.olivine"
                }
            },
            "contentName": "meta.embedded.block.olivine",
            "patterns": [
                {
                    "include": "#variable"
                },
                {
                    "name": "entity.name.function.olivine",
                    "match": "\\G\\s*[A-Za-z0-9_]*"
                },
                {
                    "include": "$self"
                }
            ]
        }
    },
    "scopeName": "source.olivine"
}
