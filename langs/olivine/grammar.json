{
    "name": "olivine",
    "patterns": [
        {
            "name": "keyword.control.olivine",
            "match": "^\\s*(?i)\\b(END|IF|ELSE|FOR|WHILE|ELIF|FUNC|RETURN|BREAK|CONTINUE)\\b"
        },
        {
            "name": "string.quoted.double.olivine",
            "begin": "'",
            "end": "'",
            "patterns": [
                {
                    "name": "constant.character.escape.olivine",
                    "match": "\\\\."
                },
                {
                    "include": "#variable"
                }
            ]
        },
        {
            "name": "constant.numeric",
            "patterns": [
                {
                    "name": "constant.numeric.integer.olivine",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        {
            "name": "comment.line.double-slash.olivine",
            "begin": "//",
            "end": "$"
        },
        {
            "include": "#variable"
        },
        {
            "match": "(!\\()\\s*([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "0": {
                    "name": "keyword.type.olivine"
                },
                "2": {
                    "name": "entity.name.function.olivine"
                }
            }
        },
        {
            "name": "entity.name.function.olivine",
            "match": "^\\s*[A-Za-z0-9_]*"
        }
    ],
    "repository": {
        "variable": {
            "match": "!+[a-zA-Z0-9_#]+",
            "name": "variable.other.olivine"
        }
    },
    "scopeName": "source.olivine"
}
