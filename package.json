{
    "name": "elydrian-langs",
    "displayName": "The Elydrian Langs",
    "description": "syntax highlighting for elydre's programming languages",
    "version": "1.0.1",
    "publisher": "elydre",
    "license": "GPL-3.0",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/elydre/elydrian-langs.git"
    },
    "engines": {
        "vscode": "^1.125.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ancolie",
                "aliases": ["Ancolie"],
                "extensions": [".li"],
                "configuration": "./langs/ancolie/config.json"
            },
            {
                "id": "olivine",
                "aliases": ["Olivine"],
                "extensions": [".olv"],
                "configuration": "./langs/olivine/config.json"
            }
        ],
        "grammars": [
            {
                "language": "ancolie",
                "scopeName": "source.ancolie",
                "path": "./langs/ancolie/grammar.json"
            },
            {
                "language": "olivine",
                "scopeName": "source.olivine",
                "path": "./langs/olivine/grammar.json"
            }
        ]
    }
}
